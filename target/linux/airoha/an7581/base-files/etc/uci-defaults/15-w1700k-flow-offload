#!/bin/sh

mkdir -p /etc/hotplug.d/net
cat > /etc/hotplug.d/net/50-flow-offload-wifi <<'HOTPLUG'
#!/bin/sh

case "$ACTION" in
	add|move) ;;
	*) exit 0 ;;
esac

DEV="${DEVICENAME:-$INTERFACE}"
[ -n "$DEV" ] || exit 0

case "$DEV" in
	phy*-ap*|ap-mld*) ;;
	*) exit 0 ;;
esac

[ -f /tmp/.flow-offload-wifi-pending ] && exit 0
touch /tmp/.flow-offload-wifi-pending

(
	sleep 10
	rm -f /tmp/.flow-offload-wifi-pending
	/etc/init.d/firewall reload
) 2>/dev/null &

exit 0
HOTPLUG
chmod +x /etc/hotplug.d/net/50-flow-offload-wifi

exit 0
